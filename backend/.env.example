# ============================================================
# Plantilla de variables de entorno para TurismoBennito
# ============================================================
# Copia este archivo como ".env" y rellena los valores reales.
# El archivo .env NUNCA se sube a GitHub.

# URI de conexión a MongoDB Atlas
MONGO_URI=mongodb+srv://USUARIO:CONTRASEÑA@CLUSTER.mongodb.net/turismoBennito?retryWrites=true&w=majority

# Clave secreta para firmar los tokens JWT (usa algo largo y aleatorio)
JWT_SECRET=cambia-esto-por-una-clave-secreta-muy-larga

# URL del frontend (opcional, para CORS en producción)
# FRONTEND_URL=https://tu-app.vercel.app
